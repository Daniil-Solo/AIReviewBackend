# application
ENV=hard_local

#Auth
AUTH_SECRET_KEY=auth-secret-key
AUTH_WELCOME_BONUS_AMOUNT=0

# Security
SECURITY_ENCRYPTION_KEY=qr1O6f037rkE6b3TPjjAF4bf47ib9thSTmUU9ju_Vz4=

# logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
LOG_LOKI_ENABLED=false
LOG_LOKI_URL=...

# postgres
POSTGRES_HOST=database
POSTGRES_PORT=5432
POSTGRES_USER=autoreviewer
POSTGRES_PASSWORD=autoreviewer
POSTGRES_DB=autoreviewer

# AI (Ollama OpenAI compatible example)
AI_LLM_API_ENDPOINT=http://host.docker.internal:11434/v1/
AI_LLM_API_KEY=ollama
AI_LLM_DEFAULT_MODEL=qwen3.5:latest
AI_LLM_DEFAULT_MODEL_INPUT_TOKEN_PRICE=0
AI_LLM_DEFAULT_MODEL_OUTPUT_TOKEN_PRICE=0

# Local Specific Settings
EMAIL_TYPE=DISABLE
STORAGE_TYPE=FILE
REDIS_ENABLED=False

# Storage
STORAGE_FILE_BASE_PATH=/app/storage

# Solutions
SOLUTION_MAX_UPLOADS_PER_TASK=1000
SOLUTION_CHECK_BALANCE_BEFORE_CREATING=False